---
import MobileNav from './MobileNav.tsx';

const navLinks = [
  { href: '/', label: 'Acasă' },
  { href: '/proiecte', label: 'Proiecte' },
  { href: '/alpha', label: 'Alpha' },
  { href: '/donatii', label: 'Donații' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 border-b border-stone-100 shadow-sm hover:shadow-md transition-shadow duration-300">
  <div class="container-site flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-text-dark hover:scale-105 transition-transform duration-300">
      <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-extrabold text-sm hover:shadow-lg hover:shadow-primary/50 transition-all duration-300">
        H
      </div>
      <span class="bg-gradient-to-r from-primary to-primary-dark bg-clip-text text-transparent hover:from-primary-dark hover:to-primary transition-all duration-300">Harmony</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navigare principală">
      {navLinks.map(link => (
        <a href={link.href}
           class="text-sm font-medium text-text-muted hover:text-primary transition-all duration-300 relative group">
          {link.label}
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-hover:w-full transition-all duration-300"></span>
        </a>
      ))}
      <a href="/contact"
         class="ml-4 px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary-dark transition-all duration-300 hover:scale-105 active:scale-95 hover:shadow-lg hover:shadow-primary/40 glow-sm">
        Planifică vizita
      </a>
    </nav>

    <!-- Mobile nav island -->
    <MobileNav client:load navLinks={navLinks} />
  </div>
</header>
