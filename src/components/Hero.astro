---
interface Props {
  headline: string;
  subheadline: string;
  ctaPrimary: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
}

const { headline, subheadline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="bg-bg-warm section-padding relative overflow-hidden">
  <div class="absolute inset-0 opacity-30 pointer-events-none">
    <div class="absolute top-10 left-10 w-72 h-72 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
  </div>
  <div class="container-site text-center max-w-3xl mx-auto relative">
    <h1 class="fade-up text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-dark leading-tight mb-6">
      {headline}
    </h1>
    <p class="fade-up text-lg sm:text-xl text-text-muted mb-10 leading-relaxed">
      {subheadline}
    </p>
    <div class="fade-up flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={ctaPrimary.href}
        class="px-8 py-4 bg-primary text-white font-bold rounded-xl text-base hover:bg-primary-dark transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105 active:scale-95 btn-scale glow-sm"
      >
        {ctaPrimary.text}
      </a>
      {ctaSecondary && (
        <a
          href={ctaSecondary.href}
          class="px-8 py-4 bg-white text-primary font-bold rounded-xl text-base border-2 border-primary hover:bg-indigo-50 transition-all duration-300 hover:scale-105 active:scale-95 btn-scale"
        >
          {ctaSecondary.text}
        </a>
      )}
    </div>
  </div>
</section>
