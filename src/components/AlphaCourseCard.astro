---
import type { AlphaGroup } from '@data/alpha';

interface Props {
  group: AlphaGroup;
}

const { group } = Astro.props;
---

<article class="fade-up rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 bg-white card-hover group">
  <div class={`bg-gradient-to-br ${group.color} p-6 text-white relative overflow-hidden`}>
    <div class="absolute -right-12 -top-12 w-40 h-40 bg-white/10 rounded-full group-hover:scale-125 transition-transform duration-500 ease-out" aria-hidden="true"></div>
    <div class="relative z-10">
      <p class="text-xs font-semibold uppercase tracking-widest opacity-80 mb-1 group-hover:opacity-100 transition-opacity duration-300">{group.ageRange}</p>
      <h3 class="text-xl font-bold group-hover:translate-x-1 transition-transform duration-300">{group.name}</h3>
      <p class="text-sm opacity-90 mt-1">{group.targetAudience}</p>
    </div>
  </div>
  <div class="p-6">
    <p class="text-text-muted text-sm leading-relaxed mb-4">{group.description}</p>
    <p class="text-xs text-text-muted mb-6">
      <span class="font-semibold text-text-dark">Program:</span>
      {group.schedule}
    </p>
    <a
      href="/contact"
      class="block w-full text-center px-4 py-3 bg-primary text-white font-semibold rounded-xl text-sm hover:bg-primary-dark transition-all duration-300 hover:scale-105 active:scale-95 glow-sm"
    >
      {group.cta}
    </a>
  </div>
</article>
