---
import type { AlphaGroup } from '@data/alpha';

interface Props {
  group: AlphaGroup;
}

const { group } = Astro.props;
---

<article class="fade-up rounded-2xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-200 bg-white">
  <div class={`bg-gradient-to-br ${group.color} p-6 text-white`}>
    <p class="text-xs font-semibold uppercase tracking-widest opacity-80 mb-1">{group.ageRange}</p>
    <h3 class="text-xl font-bold">{group.name}</h3>
    <p class="text-sm opacity-90 mt-1">{group.targetAudience}</p>
  </div>
  <div class="p-6">
    <p class="text-text-muted text-sm leading-relaxed mb-4">{group.description}</p>
    <p class="text-xs text-text-muted mb-6">
      <span class="font-semibold text-text-dark">Program:</span>
      {group.schedule}
    </p>
    <a
      href="/contact"
      class="block w-full text-center px-4 py-3 bg-primary text-white font-semibold rounded-xl text-sm hover:bg-primary-dark transition-colors"
    >
      {group.cta}
    </a>
  </div>
</article>
