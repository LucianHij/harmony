---
import type { Project } from '@data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article
  class={`fade-up rounded-2xl ${project.color} p-6 shadow-md hover:shadow-2xl transition-all duration-300 flex flex-col card-hover group relative overflow-hidden`}
>
  <div class="absolute -right-8 -top-8 w-32 h-32 bg-white/10 rounded-full group-hover:scale-150 transition-transform duration-500 ease-out" aria-hidden="true"></div>
  <div class="relative z-10 flex flex-col h-full">
    <div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300 origin-left" aria-hidden="true">{project.icon}</div>
    <h3 class="text-xl font-bold text-text-dark mb-2 group-hover:text-primary transition-colors duration-300">{project.title}</h3>
    <p class="text-sm font-medium text-primary mb-3 opacity-90 group-hover:opacity-100 transition-opacity duration-300">{project.tagline}</p>
    <p class="text-text-muted text-sm leading-relaxed flex-1">{project.description}</p>
    <a href={`/proiecte/${project.slug}`} class="mt-6 inline-flex items-center text-sm font-semibold text-primary hover:text-primary-dark transition-all duration-300 group/link">
      <span class="relative">
        {project.ctaText}
        <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-primary group-hover/link:w-full transition-all duration-300"></span>
      </span>
      <span class="ml-2 transition-transform duration-300 group-hover/link:translate-x-1">→</span>
    </a>
  </div>
</article>
