---
import MobileNav from './MobileNav.tsx';

const navLinks = [
  { href: '/', label: 'Acasă' },
  { href: '/proiecte', label: 'Proiecte' },
  { href: '/alpha', label: 'Alpha' },
  { href: '/donatii', label: 'Donații' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 border-b border-stone-100 shadow-sm">
  <div class="container-site flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 font-bold text-xl text-text-dark">
      <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center text-white font-extrabold text-sm">
        H
      </div>
      <span>Harmony</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-8" aria-label="Navigare principală">
      {navLinks.map(link => (
        <a href={link.href}
           class="text-sm font-medium text-text-muted hover:text-primary transition-colors">
          {link.label}
        </a>
      ))}
      <a href="/contact"
         class="ml-4 px-4 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary-dark transition-colors">
        Planifică vizita
      </a>
    </nav>

    <!-- Mobile nav island -->
    <MobileNav client:load navLinks={navLinks} />
  </div>
</header>
