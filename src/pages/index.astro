---
import BaseLayout from '@layouts/BaseLayout.astro';
import SundayBanner from '@components/SundayBanner.astro';
import Hero from '@components/Hero.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { projects } from '@data/projects';
---

<BaseLayout
  title="Acasă"
  description="O comunitate deschisă în locuitori. Duminică la 10:00 și 11:00–12:00."
>
  <SundayBanner />

  <Hero
    headline="Un loc unde ești binevenit"
    subheadline="O comunitate deschisă în București — un spațiu pentru întrebări, conexiuni reale și sens."
    ctaPrimary={{ text: 'Planifică prima vizită', href: '/contact' }}
    ctaSecondary={{ text: 'Descoperă proiectele', href: '/proiecte' }}
  />

  <!-- Mission section -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-2xl text-center mx-auto fade-up">
      <h2 class="text-3xl font-bold text-text-dark mb-6">De ce existăm</h2>
      <p class="text-text-muted text-lg leading-relaxed">
        Credem că fiecare persoană merită un loc în care să fie văzută, auzită și iubită — indiferent de
        background, credință sau trecut. Facem asta prin comunitate, prin proiecte sociale și printr-o invitație
        constantă la explorare.
      </p>
    </div>
  </section>

  <!-- Projects preview -->
  <section class="section-padding bg-bg-warm">
    <div class="container-site">
      <div class="text-center mb-12 fade-up">
        <h2 class="text-3xl font-bold text-text-dark mb-4">Cum ne implicăm</h2>
        <p class="text-text-muted max-w-xl mx-auto">Patru programe active, o singură misiune.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {projects.map(p => <ProjectCard project={p} />)}
      </div>
      <div class="text-center mt-10 fade-up">
        <a href="/proiecte" class="text-primary font-semibold hover:underline">
          Explorează toate proiectele →
        </a>
      </div>
    </div>
  </section>

  <!-- Alpha teaser -->
  <section class="section-padding bg-gradient-to-br from-indigo-700 to-indigo-900 text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-30 pointer-events-none">
      <div class="absolute -right-32 -top-32 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
      <div class="absolute -left-32 -bottom-32 w-96 h-96 bg-indigo-300/5 rounded-full blur-3xl"></div>
    </div>
    <div class="container-site text-center max-w-2xl mx-auto fade-up relative z-10">
      <h2 class="text-3xl font-bold mb-4">Alpha — Întrebări mari, conversații reale</h2>
      <p class="text-indigo-200 mb-8 leading-relaxed">
        Nu trebuie să crezi nimic în prealabil. Alpha e un spațiu relaxat pentru cei curioși despre credință, sens
        și viață.
      </p>
      <a
        href="/alpha"
        class="px-8 py-4 bg-white text-indigo-700 font-bold rounded-xl hover:bg-indigo-50 transition-all duration-300 inline-block hover:scale-105 active:scale-95 shadow-lg hover:shadow-2xl"
      >
        Află mai mult despre Alpha
      </a>
    </div>
  </section>

  <!-- Visit CTA -->
  <section class="section-padding bg-gradient-to-br from-accent to-amber-600 relative overflow-hidden">
    <div class="absolute inset-0 opacity-20 pointer-events-none">
      <div class="absolute -right-40 -bottom-40 w-96 h-96 bg-white/10 rounded-full blur-3xl"></div>
    </div>
    <div class="container-site text-center fade-up relative z-10">
      <h2 class="text-3xl font-bold text-white mb-4">Vino duminica aceasta</h2>
      <p class="text-amber-100 mb-8 max-w-lg mx-auto">
        Prima vizită e mereu puțin intimidantă. Suntem aici să te facem să te simți acasă.
      </p>
      <a
        href="/contact"
        class="px-8 py-4 bg-white text-amber-700 font-bold rounded-xl hover:bg-amber-50 transition-all duration-300 shadow-lg hover:shadow-2xl inline-block hover:scale-105 active:scale-95"
      >
        Planifică prima vizită
      </a>
    </div>
  </section>
</BaseLayout>
