---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.tsx';
---

<BaseLayout
  title="Contact"
  description="Contactează Biserica Harmony. Suntem aici pentru a răspunde la întrebările tale."
>
  <section class="section-padding bg-bg-warm">
    <div class="container-site max-w-3xl text-center mx-auto fade-up">
      <h1 class="text-4xl sm:text-5xl font-bold text-text-dark mb-6">Contactează-ne</h1>
      <p class="text-text-muted text-lg">
        Avem întrebări? Vrei să te implici? Suntem aici să ascultăm.
      </p>
    </div>
  </section>

  <!-- Contact info + form -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Info -->
        <div class="fade-up">
          <h2 class="text-2xl font-bold text-text-dark mb-6">Informații de contact</h2>

          <!-- Address -->
          <div class="mb-8">
            <p class="font-semibold text-text-dark mb-2">Adresă</p>
            <address class="not-italic text-text-muted">
              Biserica Harmony <br />
              Str. Exemplu nr. 12 <br />
              București, Sector 2, 020000
            </address>
          </div>

          <!-- Phone -->
          <div class="mb-8">
            <p class="font-semibold text-text-dark mb-2">Telefon</p>
            <a href="tel:+40212345678" class="text-primary hover:text-primary-dark transition-colors">
              +40 (21) 234 5678
            </a>
          </div>

          <!-- Email -->
          <div class="mb-8">
            <p class="font-semibold text-text-dark mb-2">Email</p>
            <a href="mailto:contact@harmonyro.church" class="text-primary hover:text-primary-dark transition-colors">
              contact@harmonyro.church
            </a>
          </div>

          <!-- Map -->
          <div class="rounded-lg overflow-hidden mt-8 h-64">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2835.2348820815325!2d26.089568!3d44.429029!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40b1fc0000000001%3A0x1234567890abcdef!2sBucurești!5e0!3m2!1sro!2sro!4v1234567890"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>

        <!-- Form -->
        <div class="fade-up">
          <h2 class="text-2xl font-bold text-text-dark mb-6">Trimite-ne un mesaj</h2>
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </section>

  <!-- Office hours -->
  <section class="section-padding bg-indigo-50">
    <div class="container-site max-w-3xl text-center mx-auto fade-up">
      <h2 class="text-2xl font-bold text-text-dark mb-4">Program de receptie</h2>
      <p class="text-text-muted mb-6">
        Poți vizita Biserica Harmony duminica de la 9:30 înainte de serviciu. Pentru alte zile, contactează-ne pentru o
        întâlnire.
      </p>
      <div class="bg-white rounded-lg p-6 inline-block">
        <p class="font-semibold text-text-dark">Duminică: 10:00–12:30</p>
        <p class="text-text-muted text-sm">Alte zile pe programare</p>
      </div>
    </div>
  </section>
</BaseLayout>
