---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import DonationSteps from '@components/DonationSteps.astro';
---

<BaseLayout
  title="Donații"
  description="Susține Biserica Harmony și proiectele sociale. Donații sigure prin Asociația Harmony."
>
  <Hero
    headline="Susține misiunea"
    subheadline="Donațiile tale ajută o comunitate deschisă să servească mai bine."
    ctaPrimary={{ text: 'Vreau să donez', href: '#donation-steps' }}
  />

  <!-- What donations support -->
  <section class="section-padding bg-white">
    <div class="container-site">
      <div class="mb-12 fade-up">
        <h2 class="text-3xl font-bold text-text-dark mb-6">Ce susțin donațiile tale?</h2>
        <p class="text-text-muted text-lg leading-relaxed">
          Fiecare donație susține direct misiunea noastră — de la programul de duminică și spațiul comunității, la proiectele
          sociale care fac diferență în București.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Community operations -->
        <div class="fade-up rounded-2xl border-2 border-primary p-8">
          <h3 class="text-xl font-bold text-text-dark mb-3">Comunitate și Events</h3>
          <p class="text-text-muted mb-4 text-sm">
            Programul de duminică, spațiu pentru întâlniri, și evenimentele comunitare.
          </p>
          <ul class="space-y-2 text-sm text-text-muted">
            <li>✓ Servicii de duminică și studii biblice</li>
            <li>✓ Spațiu pentru grupuri și întâlniri</li>
            <li>✓ Evenimente și programe educaționale</li>
          </ul>
        </div>

        <!-- Social impact -->
        <div class="fade-up rounded-2xl border-2 border-accent p-8">
          <h3 class="text-xl font-bold text-text-dark mb-3">Proiecte Sociale</h3>
          <p class="text-text-muted mb-4 text-sm">
            Oameni ai Străzii, Micii Exploratori, Penitenciar — impact real în comunitate.
          </p>
          <ul class="space-y-2 text-sm text-text-muted">
            <li>✓ Mese calde și ajutor pentru oamenii străzii</li>
            <li>✓ Programe pentru copii și adolescenți</li>
            <li>✓ Vizite și sprijin în penitenciar</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Donation methods -->
  <section id="donation-steps" class="section-padding bg-bg-warm">
    <div class="container-site mb-12">
      <h2 class="text-3xl font-bold text-text-dark mb-8 fade-up">Modalități de donație</h2>
    </div>
    <DonationSteps />
  </section>

  <!-- Transparency -->
  <section class="section-padding bg-white">
    <div class="container-site max-w-3xl mx-auto">
      <div class="fade-up">
        <h2 class="text-2xl font-bold text-text-dark mb-4">Transparență și încredere</h2>
        <p class="text-text-muted leading-relaxed mb-4">
          Fiecare donație este gestionată cu integritate. Biserica Harmony publică rapoarte anuale despre cum sunt
          folosite resursele. Dacă vrei mai multe detalii, nu ezita să ne contactezi.
        </p>
        <p class="text-text-muted leading-relaxed">
          Suntem aici pentru a servi. Apreciem enorm dacă poți susține misiunea noastră.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding bg-primary text-white">
    <div class="container-site text-center max-w-2xl mx-auto fade-up">
      <h2 class="text-2xl font-bold mb-4">Întrebări despre donații?</h2>
      <p class="text-indigo-200 mb-8">
        Suntem deschiși la orice discuții. Contactează-ne cu orice clarificări.
      </p>
      <a
        href="/contact"
        class="px-8 py-4 bg-white text-primary font-bold rounded-xl hover:bg-indigo-50 transition-colors inline-block"
      >
        Contactează-ne
      </a>
    </div>
  </section>
</BaseLayout>
