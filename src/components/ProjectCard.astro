---
import type { Project } from '@data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article
  class={`fade-up rounded-2xl ${project.color} p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200 flex flex-col`}
>
  <div class="text-4xl mb-4" aria-hidden="true">{project.icon}</div>
  <h3 class="text-xl font-bold text-text-dark mb-2">{project.title}</h3>
  <p class="text-sm font-medium text-primary mb-3">{project.tagline}</p>
  <p class="text-text-muted text-sm leading-relaxed flex-1">{project.description}</p>
  <a href={`/proiecte/${project.slug}`} class="mt-6 inline-flex items-center text-sm font-semibold text-primary hover:text-primary-dark transition-colors">
    {project.ctaText} <span class="ml-1">→</span>
  </a>
</article>
