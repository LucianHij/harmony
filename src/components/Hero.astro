---
interface Props {
  headline: string;
  subheadline: string;
  ctaPrimary: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
}

const { headline, subheadline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="bg-bg-warm section-padding">
  <div class="container-site text-center max-w-3xl mx-auto">
    <h1 class="fade-up text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-dark leading-tight mb-6">
      {headline}
    </h1>
    <p class="fade-up text-lg sm:text-xl text-text-muted mb-10 leading-relaxed" style="transition-delay: 0.1s">
      {subheadline}
    </p>
    <div class="fade-up flex flex-col sm:flex-row gap-4 justify-center" style="transition-delay: 0.2s">
      <a
        href={ctaPrimary.href}
        class="px-8 py-4 bg-primary text-white font-bold rounded-xl text-base hover:bg-primary-dark transition-colors shadow-md"
      >
        {ctaPrimary.text}
      </a>
      {ctaSecondary && (
        <a
          href={ctaSecondary.href}
          class="px-8 py-4 bg-white text-primary font-bold rounded-xl text-base border-2 border-primary hover:bg-indigo-50 transition-colors"
        >
          {ctaSecondary.text}
        </a>
      )}
    </div>
  </div>
</section>
